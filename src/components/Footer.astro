---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/8 mt-24">
  <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <div
        class="w-7 h-7 rounded-md bg-gradient-to-br from-violet-500 to-indigo-500 flex items-center justify-center text-white text-xs font-bold"
      >
        A
      </div>
      <span class="text-sm text-slate-400">
        <span class="text-white font-medium">alhabibi.org</span> — AI Agent Showcase
      </span>
    </div>

    <div class="flex items-center gap-6 text-sm text-slate-500">
      <a href="/#agents" class="hover:text-slate-300 transition-colors">Agents</a>
      <a href="/blog" class="hover:text-slate-300 transition-colors">Blog</a>
      <span>© {year}</span>
    </div>
  </div>
</footer>
