---
---

<section class="relative min-h-screen flex items-center justify-center px-6 overflow-hidden">
  <!-- Decorative orbs -->
  <div
    class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full float"
    style="background: radial-gradient(circle, rgba(139,92,246,0.18) 0%, transparent 70%); filter: blur(60px); animation-delay: 0s;"
  >
  </div>
  <div
    class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full float"
    style="background: radial-gradient(circle, rgba(99,102,241,0.14) 0%, transparent 70%); filter: blur(60px); animation-delay: -3s;"
  >
  </div>

  <div class="relative text-center max-w-4xl mx-auto pt-16">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 glass px-4 py-2 text-sm text-violet-300 mb-8 fade-in-up" style="animation-delay: 0.1s;">
      <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
      Hobby Project · AI Agents Catalogue
    </div>

    <!-- Heading -->
    <h1
      class="text-5xl md:text-7xl font-extrabold text-white leading-tight mb-6 fade-in-up"
      style="animation-delay: 0.2s;"
    >
      Meet the<br />
      <span class="gradient-text">Agents</span>
    </h1>

    <!-- Subheading -->
    <p
      class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed fade-in-up"
      style="animation-delay: 0.35s;"
    >
      A collection of AI agents I'm building as a hobby — each one designed to
      think, reason, and act autonomously. Explore the catalogue, read about the
      journey, and try them live.
    </p>

    <!-- CTAs -->
    <div
      class="flex flex-col sm:flex-row gap-4 justify-center fade-in-up"
      style="animation-delay: 0.5s;"
    >
      <a
        href="/#agents"
        class="px-8 py-3.5 rounded-xl bg-gradient-to-r from-violet-600 to-indigo-600 text-white font-semibold hover:from-violet-500 hover:to-indigo-500 transition-all shadow-lg shadow-violet-500/25 hover:shadow-violet-500/40 hover:-translate-y-0.5"
      >
        Browse Catalogue
      </a>
      <a
        href="/blog"
        class="px-8 py-3.5 rounded-xl glass text-slate-200 font-semibold hover:text-white glass-hover"
      >
        Read the Blog
      </a>
    </div>

    <!-- Scroll hint -->
    <div class="mt-20 flex flex-col items-center gap-2 text-slate-500 text-xs fade-in-up" style="animation-delay: 0.8s;">
      <span>Scroll to explore</span>
      <div class="w-px h-8 bg-gradient-to-b from-slate-500 to-transparent"></div>
    </div>
  </div>
</section>
