---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import DemoWidget from "../../components/DemoWidget";

export async function getStaticPaths() {
  const agents = await getCollection("agents");
  return agents.map((agent) => ({
    params: { slug: agent.id.replace(/\.mdx?$/, "") },
    props: { agent },
  }));
}

const { agent } = Astro.props;
const { Content } = await render(agent);

const statusConfig = {
  active: { label: "Active", cls: "bg-emerald-500/20 text-emerald-300 border-emerald-500/30" },
  beta: { label: "Beta", cls: "bg-amber-500/20 text-amber-300 border-amber-500/30" },
  "coming-soon": { label: "Coming Soon", cls: "bg-slate-500/20 text-slate-400 border-slate-500/30" },
};

const categoryColor: Record<string, string> = {
  productivity: "text-blue-300",
  creative: "text-pink-300",
  research: "text-teal-300",
  utility: "text-orange-300",
};

const sc = statusConfig[agent.data.status];
---

<Base title={`${agent.data.name} — Al Habibi`} description={agent.data.description}>
  <div class="max-w-3xl mx-auto px-6 py-32">
    <a
      href="/#agents"
      class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-violet-400 transition-colors mb-12"
    >
      ← All Agents
    </a>

    <!-- Agent header -->
    <div class="glass p-8 mb-8 fade-in-up">
      <div class="flex items-start gap-6">
        <div class="text-6xl">{agent.data.icon}</div>
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-3 mb-2">
            <h1 class="text-3xl font-bold text-white">{agent.data.name}</h1>
            <span class={`text-xs px-2.5 py-1 rounded-full border font-medium ${sc.cls}`}>
              {sc.label}
            </span>
          </div>
          <p class={`text-sm font-medium capitalize mb-3 ${categoryColor[agent.data.category]}`}>
            {agent.data.category}
          </p>
          <p class="text-slate-400 leading-relaxed">{agent.data.description}</p>
        </div>
      </div>

      <!-- Tech stack -->
      <div class="mt-6 pt-6 border-t border-white/8 flex flex-wrap gap-2">
        {
          agent.data.techStack.map((tech) => (
            <span
              class="text-xs px-3 py-1 rounded-full text-slate-300 border border-white/10"
              style="background: rgba(255,255,255,0.05);"
            >
              {tech}
            </span>
          ))
        }
      </div>
    </div>

    <!-- Live Demo -->
    <div class="mb-8 fade-in-up" style="animation-delay: 0.15s;">
      <h2 class="text-lg font-semibold text-white mb-4">Try it Live</h2>
      <DemoWidget
        demoType={agent.data.demoType}
        demoUrl={agent.data.demoUrl}
        agentName={agent.data.name}
        client:load
      />
    </div>

    <!-- Content -->
    <div class="glass p-8 fade-in-up" style="animation-delay: 0.3s;">
      <div class="prose prose-invert max-w-none">
        <Content />
      </div>
    </div>
  </div>
</Base>
